{% extends "layouts/base.twig" %}

{% set palette = page.meta('palette')|default('lavender-light') %}

{% block pageBody %}
  {% include 'templates/components/toppers/landing-topper.twig' with {
    layout: page.meta('layout'),
    subtitle: page.meta('subtitle'),
    headline: page.meta('headline'),
    introduction: page.meta('introduction'),
    cta: page.meta('cta'),
    images: page.meta('images'),
    images_dual: page.meta('images_dual'),
    image_single: page.meta('image_single'),
    palette: page.meta('palette')
  } %}

  <article class="gutenberg rich-text">
    {{ post.content }}
  </article>
{% endblock %}
