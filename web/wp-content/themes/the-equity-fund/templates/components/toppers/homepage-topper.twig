<header class="palette-lavender bg-background px-site-padding pb-12 md:pb-16 pt-topper-margin size-{{ size|default('large') }}">
  <div class="relative">

    <figure class="w-full xl:w-[80%] mx-auto relative">

      {% if hero_video %}

        <div class="w-full aspect-[16/9] overflow-hidden">

          <video
            class="w-full h-full object-cover cursor-pointer"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            data-ambient-video
          >
            <source src="{{ hero_video }}" type="video/mp4">
          </video>

        </div>

      {% else %}

        {# MOBILE #}
        {% if image_mobile %}
          <div class="[display:block] md:[display:none] w-full">
            {% include 'templates/components/lazy-img.twig' with {
              img: get_image(image_mobile),
              aspectRatio: 'horizontal',
            } %}
          </div>
        {% endif %}

        {# DESKTOP #}
        {% if image %}
          <div class="[display:none] md:[display:block] w-full">
            {% include 'templates/components/lazy-img.twig' with {
              img: get_image(image),
              aspectRatio: 'wide',
            } %}
          </div>
        {% endif %}
      {% endif %}

    </figure>

    <h1 class="w-full font-display text-maroon font-medium text-center uppercase leading-[1] text-[20vw] sm:text-[18vw] md:text-[16vw] absolute left-1/2 -translate-x-1/2 top-full -translate-y-1/4">
        {{ headline }}
    </h1>
  </div>

  <div class="text-foreground mt-[4vw] pt-16 sm:pt-20 lg:pt-28 xl:pt-36 text-center">
      <p class="text-base md:text-lg lg:text-xl xl:text-2xl font-serif mx-auto max-w-[50rem]">
          {{ introduction }}
      </p>
  </div>
</header>
