<div class="flex flex-col items-center text-center gap-6 md:gap-10 px-site-padding pt-[100px] md:pt-topper-margin pb-[50px] md:pb-[100px]">

  {% if subtitle %}
    <p class="uppercase font-bold max-lg:text-sm tracking-wide mt-[20px] md:mt-[50px]">{{ subtitle }}</p>
  {% endif %}

  <h1 class="font-display font-medium uppercase text-[clamp(4rem,8.33vw,7.5rem)] leading-[0.8] tracking-[-0.125px]">{{ headline }}</h1>

  {% if introduction %}
    <p class="font-serif font-normal text-[24px] leading-[1.2] tracking-[-0.72px] max-w-2xl">{{ introduction|striptags('<em><strong><a>')|raw }}</p>
  {% endif %}

  {% if cta %}
    <a
      class="uppercase leading-[1] text-sm lg:text-base font-bold tracking-wide px-4 pb-2 pt-3 text-button-foreground bg-button-background hocus:bg-button-hover-background hocus:text-button-hover-foreground transition-all"
      href="{{ cta.url }}"
      target="{{ cta.target }}"
      {% if cta.target == '_blank' %}rel="noopener noreferrer"{% endif %}
    >{{ cta.title }}</a>
  {% endif %}

</div>

{% if image_single %}
  <div class="w-full">
    {% include 'templates/components/lazy-img.twig' with { img: get_image(image_single) } %}
  </div>
{% endif %}
