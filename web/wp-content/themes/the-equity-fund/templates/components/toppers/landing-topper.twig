{% set palette = palette|default('lavender-light') %}
{% set layout = layout|default('image_grid') %}

<header class="palette-{{ palette }} bg-background text-foreground">
  {% if layout == 'image_grid' %}
    {% include 'templates/components/toppers/landing-topper--image-grid.twig' %}
  {% elseif layout == 'dual_image' %}
    {% include 'templates/components/toppers/landing-topper--dual-image.twig' %}
  {% elseif layout == 'single_image' %}
    {% include 'templates/components/toppers/landing-topper--single-image.twig' %}
  {% endif %}
</header>
